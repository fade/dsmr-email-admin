#!/bin/bash
# dsmr-email-admin — health check and repair for the DSMR qmail/vpopmail/dovecot
# mail stack.  Generalises the manual verification-and-fix steps that recur on
# DSMR hosts whose control/config files predate a packaging fix (a postinst that
# only creates a file "if absent" never repairs an existing one on upgrade).
#
# Subcommands:
#   check                Read-only health check of the whole stack.
#   fix [--dry-run] [TARGET...]
#                        Repair detected issues.  TARGETs:
#                          softlimit pgsql-config dovecot-sql pg-cluster
#                        With no TARGET, fixes every issue detected.
#   selftest [ADDR]      End-to-end probe: create a throwaway vpopmail mailbox,
#                        inject a message, confirm delivery + dovecot auth, then
#                        clean up.  Mutating but self-contained.
#   version | help
#
# Fixes back up every file they touch (<file>.bak-<timestamp>) and never rewrite
# a value the admin set deliberately beyond the known-bad cases below.
#
# 🄯 Brian O'Reilly <fade@deepsky.com>, 2026

set -uo pipefail

VPOPMAIL_PGSQL=/home/vpopmail/etc/vpopmail.pgsql
DOVECOT_SQL=/etc/dovecot/dovecot-vpopmail-sql.conf.ext
QCONTROL=/var/lib/qmail/control
SOFTLIMIT_FILE="$QCONTROL/softlimit"
SOFTLIMIT_MIN=100000000
VPOPBIN=/home/vpopmail/bin
QBIN=/var/lib/qmail/bin

# Authentication-DNS (DKIM/SPF) management.  Defaults; the dkim/spf/authdns
# subcommands accept flags to override per invocation.
VPOPDOMAINS=/home/vpopmail/domains
DKIM_SELECTOR=default
DKIM_BITS=2048
SPF_QUALIFIER="~all"          # softfail by default; --hard switches to -all
# The host outbound mail leaves from (used in the SPF 'a:' mechanism).
RELAYHOST="$(hostname -f 2>/dev/null)"
[ -n "$RELAYHOST" ] || RELAYHOST="$(head -1 "$QCONTROL/me" 2>/dev/null)"
# Where per-domain, copy-pasteable DNS record files are written.  We do not
# touch any nameserver — the operator publishes these by hand.
AUTHDNS_OUT=/var/lib/qmail/control/authdns

# qmail queue root (for the reputation/backscatter diagnostics).
QUEUE=/var/lib/qmail/queue

green='\033[0;32m'; red='\033[0;31m'; yellow='\033[0;33m'; reset='\033[0m'
PASS=0; FAIL=0; WARN=0
ok()   { printf "${green}PASS${reset} %s\n" "$1"; PASS=$((PASS+1)); }
bad()  { printf "${red}FAIL${reset} %s\n" "$1"; FAIL=$((FAIL+1)); }
warn() { printf "${yellow}WARN${reset} %s\n" "$1"; WARN=$((WARN+1)); }
info() { printf "     %s\n" "$1"; }
die()  { echo "dsmr-email-admin: error: $*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || die "must run as root"; }

# Locate the daemontools scan directory that supervises qmail.
svdir() {
    local d
    for d in /etc/service /service /var/lib/qmail/supervise; do
        [ -d "$d/qmail-send" ] && { echo "$d"; return 0; }
    done
    echo /etc/service
}
SV="$(svdir)"

# Parse vpopmail.pgsql (host|port|user|password|database) into PG_* globals.
PG_HOST=""; PG_PORT=""; PG_USER=""; PG_PASS=""; PG_DB=""
load_pg_config() {
    [ -f "$VPOPMAIL_PGSQL" ] || return 1
    IFS='|' read -r PG_HOST PG_PORT PG_USER PG_PASS PG_DB \
        < <(grep -vE '^\s*#|^\s*$' "$VPOPMAIL_PGSQL" | head -1)
    [ -n "$PG_HOST" ] && [ -n "$PG_PORT" ] && [ -n "$PG_USER" ]
}

# ── detectors (return 0 when the named problem is present) ─────────────────────

softlimit_value() { tr -cd '0-9' < "$SOFTLIMIT_FILE" 2>/dev/null; }
softlimit_low() {
    local v; v="$(softlimit_value)"
    [ -n "$v" ] && [ "$v" -lt "$SOFTLIMIT_MIN" ]
}

# True when vpopmail.pgsql has password/database swapped: the file as written
# can't authenticate, but swapping fields 4 and 5 can.
pgsql_swapped() {
    command -v psql >/dev/null 2>&1 || return 1
    PGPASSWORD="$PG_PASS" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" \
        -d "$PG_DB" -tAc 'SELECT 1' >/dev/null 2>&1 && return 1
    PGPASSWORD="$PG_DB" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" \
        -d "$PG_PASS" -tAc 'SELECT 1' >/dev/null 2>&1
}

# Echo "ver cluster status" for the postgres cluster on the vpopmail port.
pg_cluster_row() {
    command -v pg_lsclusters >/dev/null 2>&1 || return 1
    pg_lsclusters -h 2>/dev/null | awk -v p="$PG_PORT" '$3==p{print $1, $2, $4; found=1} END{exit !found}'
}
pg_cluster_down() {
    local row; row="$(pg_cluster_row)" || return 1
    [ "$(echo "$row" | awk '{print $3}')" != "online" ]
}

# True when the generated dovecot SQL conf disagrees with vpopmail.pgsql.
dovecot_sql_stale() {
    [ -f "$DOVECOT_SQL" ] || return 1
    local cdb cuser cpass
    cdb=$(sed -n 's/^[[:space:]]*dbname[[:space:]]*=[[:space:]]*//p'   "$DOVECOT_SQL")
    cuser=$(sed -n 's/^[[:space:]]*user[[:space:]]*=[[:space:]]*//p'    "$DOVECOT_SQL")
    cpass=$(sed -n 's/^[[:space:]]*password[[:space:]]*=[[:space:]]*//p' "$DOVECOT_SQL")
    [ "$cdb" = "$PG_DB" ] && [ "$cuser" = "$PG_USER" ] && [ "$cpass" = "$PG_PASS" ] && return 1
    return 0
}

# ── check ─────────────────────────────────────────────────────────────────────
cmd_check() {
    need_root
    echo "=== DSMR mail stack health check ==="
    echo

    echo "--- packages ---"
    local pkg st
    for pkg in qmail vpopmail dovecot-core dovecot-pgsql dovecot-vpopmail \
               dsmr-qmail-run dsmr-checkpassword-dovecot; do
        st=$(dpkg-query -W -f='${db:Status-Abbrev}' "$pkg" 2>/dev/null)
        [ "$st" = "ii " ] && ok "$pkg installed" || warn "$pkg not installed ($st)"
    done
    echo

    echo "--- services ---"
    pgrep -x svscan >/dev/null && ok "svscan running" || bad "svscan not running"
    systemctl is-active --quiet dovecot && ok "dovecot active" || bad "dovecot inactive"
    local s
    for s in qmail-send qmail-smtpd qmail-submission; do
        if command -v svstat >/dev/null 2>&1 && svstat "$SV/$s" 2>/dev/null | grep -q ": up"; then
            ok "$s up"; else warn "$s not up"; fi
    done
    echo

    echo "--- postgresql backend ---"
    if load_pg_config; then
        ok "vpopmail.pgsql parsed (host=$PG_HOST port=$PG_PORT db=$PG_DB)"
        if pg_cluster_down; then
            bad "postgres cluster on port $PG_PORT is down — run: dsmr-email-admin fix pg-cluster"
        else
            local row; row="$(pg_cluster_row 2>/dev/null)"
            [ -n "$row" ] && ok "postgres cluster online ($row)" || info "cluster status unknown (not a local pg cluster?)"
        fi
        if "$VPOPBIN"/vdominfo >/dev/null 2>&1 || ! "$VPOPBIN"/vdominfo 2>&1 | grep -qi password; then
            ok "vpopmail authenticates to postgres"
        else
            bad "vpopmail cannot authenticate to postgres"
        fi
        if pgsql_swapped; then
            bad "vpopmail.pgsql has password/database fields SWAPPED — run: dsmr-email-admin fix pgsql-config"
        else
            ok "vpopmail.pgsql field order correct"
        fi
        if dovecot_sql_stale; then
            bad "dovecot SQL conf out of sync with vpopmail.pgsql — run: dsmr-email-admin fix dovecot-sql"
        else
            ok "dovecot SQL conf matches vpopmail.pgsql"
        fi
    else
        bad "cannot read/parse $VPOPMAIL_PGSQL"
    fi
    echo

    echo "--- qmail-smtpd softlimit (OpenSSL+krb5 load) ---"
    local sv; sv="$(softlimit_value)"
    if softlimit_low; then
        bad "softlimit is $sv (< $SOFTLIMIT_MIN) — smtpd may fail to load; run: dsmr-email-admin fix softlimit"
    else
        ok "softlimit is ${sv:-unset} (>= $SOFTLIMIT_MIN)"
    fi
    # Active proof: does smtpd actually greet on :25?
    if command -v python3 >/dev/null 2>&1; then
        if python3 - <<'PY' 2>/dev/null
import socket,sys
s=socket.create_connection(("127.0.0.1",25),5)
sys.exit(0 if s.recv(64).startswith(b"220") else 1)
PY
        then ok "smtpd :25 greets (220)"; else bad "smtpd :25 did not greet — check softlimit / libraries"; fi
    fi
    echo

    echo "--- relay rules ---"
    local f
    for f in tcp.smtp tcp.submission; do
        if grep -q 'RELAYCLIENT' "$QCONTROL/$f" 2>/dev/null; then
            ok "$f has a RELAYCLIENT rule (localhost relay)"
        else
            warn "$f has no RELAYCLIENT rule"
        fi
    done
    echo

    echo "--- listening ports ---"
    local p
    for p in 25 587 143 993; do
        if ss -tlnH "( sport = :$p )" 2>/dev/null | grep -q .; then ok "port $p listening"; else warn "port $p not listening"; fi
    done
    echo

    echo "=== summary: ${PASS} pass, ${WARN} warn, ${FAIL} fail ==="
    [ "$FAIL" -eq 0 ] || { echo "Run 'dsmr-email-admin fix' to repair, or 'fix --dry-run' to preview."; return 1; }
    return 0
}

# ── fixes ─────────────────────────────────────────────────────────────────────
DRY=0
backup() { cp -a "$1" "$1.bak-$(date +%Y%m%d-%H%M%S)"; }

fix_softlimit() {
    local cur; cur="$(softlimit_value)"
    if ! softlimit_low; then info "softlimit OK (${cur:-unset})"; return 0; fi
    if [ "$DRY" = 1 ]; then echo "  would: set $SOFTLIMIT_FILE 100000000 (was $cur); restart smtpd+submission"; return 0; fi
    need_root
    backup "$SOFTLIMIT_FILE"
    printf '%s\n' "$SOFTLIMIT_MIN" > "$SOFTLIMIT_FILE"
    svc -t "$SV/qmail-smtpd" "$SV/qmail-submission" 2>/dev/null || true
    ok "softlimit raised to $SOFTLIMIT_MIN; restarted smtpd + submission"
}

fix_pg_cluster() {
    load_pg_config || { bad "cannot read $VPOPMAIL_PGSQL"; return 1; }
    if ! pg_cluster_down; then info "postgres cluster on port $PG_PORT already online"; return 0; fi
    local ver clu; read -r ver clu _ < <(pg_cluster_row)
    [ -n "$ver" ] || { bad "no local pg cluster found on port $PG_PORT"; return 1; }
    if [ "$DRY" = 1 ]; then echo "  would: pg_ctlcluster $ver $clu start; systemctl enable postgresql@$ver-$clu"; return 0; fi
    need_root
    pg_ctlcluster "$ver" "$clu" start || systemctl start "postgresql@$ver-$clu"
    systemctl enable "postgresql@$ver-$clu" >/dev/null 2>&1 || true
    ok "started + enabled postgres cluster $ver/$clu (port $PG_PORT)"
}

fix_pgsql_config() {
    load_pg_config || { bad "cannot read $VPOPMAIL_PGSQL"; return 1; }
    if ! pgsql_swapped; then info "vpopmail.pgsql field order OK"; return 0; fi
    if [ "$DRY" = 1 ]; then echo "  would: swap password/database fields in $VPOPMAIL_PGSQL, then regenerate dovecot SQL conf"; return 0; fi
    need_root
    backup "$VPOPMAIL_PGSQL"
    local tmp; tmp=$(mktemp)
    awk -F'|' 'BEGIN{OFS="|"} {t=$4;$4=$5;$5=t} 1' "$VPOPMAIL_PGSQL" > "$tmp"
    chown root:vchkpw "$tmp" 2>/dev/null || true; chmod 640 "$tmp"
    mv -f "$tmp" "$VPOPMAIL_PGSQL"
    ok "swapped vpopmail.pgsql password/database fields"
    load_pg_config
    fix_dovecot_sql
}

# Regenerate the dovecot pgsql connection conf from vpopmail.pgsql (matches the
# dovecot-vpopmail postinst format).
fix_dovecot_sql() {
    load_pg_config || { bad "cannot read $VPOPMAIL_PGSQL"; return 1; }
    if ! dovecot_sql_stale; then info "dovecot SQL conf already matches vpopmail.pgsql"; return 0; fi
    if [ "$DRY" = 1 ]; then echo "  would: regenerate $DOVECOT_SQL from vpopmail.pgsql; reload dovecot"; return 0; fi
    need_root
    [ -f "$DOVECOT_SQL" ] && backup "$DOVECOT_SQL"
    local port_line=""
    case "$PG_PORT" in 5432|0|"") ;; *) port_line="    port = ${PG_PORT}" ;; esac
    {
        echo "# PostgreSQL connection for vpopmail authentication (generated by dsmr-email-admin)."
        echo "sql_driver = pgsql"
        echo "pgsql ${PG_HOST} {"
        echo "  parameters {"
        echo "    dbname = ${PG_DB}"
        echo "    user = ${PG_USER}"
        echo "    password = ${PG_PASS}"
        [ -n "$port_line" ] && echo "$port_line"
        echo "  }"
        echo "}"
    } > "$DOVECOT_SQL"
    chown root:dovecot "$DOVECOT_SQL"; chmod 640 "$DOVECOT_SQL"
    doveadm reload 2>/dev/null || systemctl reload dovecot 2>/dev/null || true
    ok "regenerated dovecot SQL conf and reloaded dovecot"
}

cmd_fix() {
    local targets=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run|-n) DRY=1 ;;
            softlimit|pgsql-config|dovecot-sql|pg-cluster) targets+=("$1") ;;
            *) die "unknown fix target: $1 (softlimit pgsql-config dovecot-sql pg-cluster)" ;;
        esac
        shift
    done
    [ "$DRY" = 1 ] && echo "(dry-run — no changes will be made)"
    if [ "${#targets[@]}" -eq 0 ]; then targets=(pg-cluster pgsql-config dovecot-sql softlimit); fi
    local t
    for t in "${targets[@]}"; do
        echo "==> $t"
        case "$t" in
            softlimit)    fix_softlimit ;;
            pg-cluster)   fix_pg_cluster ;;
            pgsql-config) fix_pgsql_config ;;
            dovecot-sql)  fix_dovecot_sql ;;
        esac
    done
}

# ── selftest (mutating, self-contained) ───────────────────────────────────────
cmd_selftest() {
    need_root
    load_pg_config || die "cannot read $VPOPMAIL_PGSQL"
    local dom user pass vdir before after rc=0
    dom="${1:-}"
    if [ -z "$dom" ]; then
        dom=$("$VPOPBIN"/vdominfo 2>/dev/null | awk '/^domain:/{print $2; exit}')
        [ -n "$dom" ] || die "no vpopmail domain found; pass one: dsmr-email-admin selftest <domain>"
    fi
    user="dsmr-selftest-$$@${dom}"; pass="St!$$test"
    echo "selftest domain: $dom (throwaway user $user)"
    "$VPOPBIN"/vadduser "$user" "$pass" >/dev/null 2>&1 || die "vadduser failed"
    vdir=$("$VPOPBIN"/vuserinfo "$user" 2>/dev/null | awk '/^dir:/{print $2}')

    before=$(find "$vdir/Maildir/new" -type f 2>/dev/null | wc -l)
    printf 'From: selftest@%s\r\nTo: %s\r\nSubject: dsmr selftest\r\n\r\nbody\r\n' "$(hostname -f)" "$user" \
        | "$QBIN/qmail-inject" -f "selftest@$(hostname -f)" "$user"
    sleep 3
    after=$(find "$vdir/Maildir/new" -type f 2>/dev/null | wc -l)
    [ "$after" -gt "$before" ] && ok "virtual delivery ($before -> $after)" || bad "virtual delivery failed"

    if doveadm auth test "$user" "$pass" 2>&1 | grep -q 'auth succeeded'; then
        ok "dovecot authentication (pgsql passdb)"; else bad "dovecot authentication failed"; rc=1; fi

    "$VPOPBIN"/vdeluser "$user" >/dev/null 2>&1 || warn "could not delete throwaway user $user"
    echo "=== selftest: ${PASS} pass, ${FAIL} fail ==="
    [ "$FAIL" -eq 0 ] && return 0 || return 1
}

# ── DKIM / SPF authentication-DNS management ───────────────────────────────────
#
# DKIM signing happens on this (the sending) MTA via qmail-dkim, keyed off
# control/domainkeys/<domain>:<selector>.  These subcommands generate the
# signing key, install it so outbound mail signs immediately, and write a
# per-domain file of copy-pasteable SPF + DKIM (and an optional DMARC) records
# for manual entry at whatever nameserver hosts each domain.  No nameserver is
# written to directly.

# The qmail-dkim signing key directory: control/filterargs DKIMSIGNKEYDIR if set,
# else control/domainkeys.
dkim_keydir() {
    local d
    d=$(sed -n 's/.*DKIMSIGNKEYDIR=\([^[:space:]]*\).*/\1/p' "$QCONTROL/filterargs" 2>/dev/null | head -1)
    [ -n "$d" ] && echo "$d" || echo "$QCONTROL/domainkeys"
}

is_vdomain() { [ -d "$VPOPDOMAINS/$1" ] || "$VPOPBIN/vdominfo" "$1" >/dev/null 2>&1; }

# Split a string into 255-char, double-quoted chunks (DNS TXT strings cap at 255).
txt_chunks() {
    local s="$1" out="" i=0 len=${#1}
    while [ "$i" -lt "$len" ]; do out="$out \"${s:$i:255}\""; i=$((i+255)); done
    echo "${out# }"
}

# base64 SubjectPublicKeyInfo (matches the existing :default.pub format) from a key.
dkim_pubkey() { openssl pkey -in "$1" -pubout -outform DER 2>/dev/null | base64 -w0; }

build_spf()        { echo "v=spf1 a:${RELAYHOST} ${SPF_QUALIFIER}"; }
build_dkim_value() { echo "v=DKIM1; k=rsa; p=$1"; }
build_dmarc()      { echo "v=DMARC1; p=none; rua=mailto:postmaster@$1"; }

# Extract the v=spf1 TXT (if any) currently published for a domain.
spf_published() { dig +short TXT "$1" 2>/dev/null | tr -d '"' | grep -i '^[[:space:]]*v=spf1' | head -1; }

# Write the per-domain pasteable record file; echo its path.
write_records_file() {
    local domain="$1" pub="$2" file spf dkimval dmarc
    mkdir -p "$AUTHDNS_OUT"
    file="$AUTHDNS_OUT/$domain"
    spf="$(build_spf)"; dkimval="$(build_dkim_value "$pub")"; dmarc="$(build_dmarc "$domain")"
    {
        echo "; DNS authentication records for ${domain}"
        echo "; Generated by dsmr-email-admin $(date -u +%Y-%m-%dT%H:%M:%SZ)."
        echo "; Publish these at the nameserver hosting ${domain}, then verify:"
        echo ";   dsmr-email-admin spf  verify ${domain}"
        echo ";   dsmr-email-admin dkim verify ${domain}"
        echo "; A registrar web form usually wants the host/name and value separately;"
        echo "; BIND/zone files want the zone-file line.  Both are given for each record."
        echo ""
        echo "; ===== SPF — TXT at the domain apex ====="
        echo ";   host/name : @   (the bare domain ${domain})"
        echo ";   value     : ${spf}"
        printf '%s.\tIN TXT\t"%s"\n' "${domain}" "${spf}"
        echo ""
        echo "; ===== DKIM — TXT at ${DKIM_SELECTOR}._domainkey.${domain} ====="
        echo ";   host/name : ${DKIM_SELECTOR}._domainkey"
        echo ";   value (one string; most registrars re-chunk >255 automatically):"
        echo ";   ${dkimval}"
        printf '%s._domainkey.%s.\tIN TXT\t( %s )\n' "${DKIM_SELECTOR}" "${domain}" "$(txt_chunks "$dkimval")"
        echo ""
        echo "; ===== DMARC — optional but recommended; TXT at _dmarc.${domain} ====="
        echo ";   host/name : _dmarc"
        echo ";   value     : ${dmarc}"
        printf ';_dmarc.%s.\tIN TXT\t"%s"\n' "${domain}" "${dmarc}"
    } > "$file"
    echo "$file"
}

cmd_dkim() {
    local keydir; keydir="$(dkim_keydir)"
    local action="${1:-}"; shift || true
    case "$action" in
        list)
            printf "%-32s %-6s %s\n" "DOMAIN" "KEY" "(selector ${DKIM_SELECTOR})"
            local d kf n=0 have=0
            for d in $(ls "$VPOPDOMAINS" 2>/dev/null | sort); do
                kf="$keydir/$d:$DKIM_SELECTOR"; n=$((n+1))
                if [ -f "$kf" ]; then printf "%-32s %-6s\n" "$d" "yes"; have=$((have+1))
                else printf "%-32s %-6s\n" "$d" "—"; fi
            done
            echo "--- ${have}/${n} domains have a DKIM signing key ---"
            ;;
        genkey)
            local domain="" force=0
            while [ $# -gt 0 ]; do case "$1" in
                -s|--selector) DKIM_SELECTOR="$2"; shift 2 ;;
                -b|--bits)     DKIM_BITS="$2"; shift 2 ;;
                --force|-f)    force=1; shift ;;
                -*)            die "dkim genkey: unknown option $1" ;;
                *)             domain="$1"; shift ;;
            esac; done
            [ -n "$domain" ] || die "usage: dkim genkey <domain> [-s selector] [-b bits] [--force]"
            need_root
            is_vdomain "$domain" || warn "$domain is not a local vpopmail domain (generating anyway)"
            mkdir -p "$keydir"
            local kf="$keydir/$domain:$DKIM_SELECTOR"
            if [ -f "$kf" ] && [ "$force" != 1 ]; then
                die "key already exists: $kf (use --force to regenerate; rotating a published selector breaks signatures until DNS catches up)"
            fi
            [ -f "$kf" ] && backup "$kf"
            [ -f "$kf.pub" ] && backup "$kf.pub"
            openssl genpkey -algorithm RSA -pkeyopt "rsa_keygen_bits:$DKIM_BITS" -out "$kf" 2>/dev/null \
                || die "openssl key generation failed"
            chown root:qmail "$kf" 2>/dev/null || true; chmod 640 "$kf"
            local pub; pub="$(dkim_pubkey "$kf")"
            printf '%s\n' "$pub" > "$kf.pub"
            chown root:qmail "$kf.pub" 2>/dev/null || true; chmod 644 "$kf.pub"
            ok "generated ${DKIM_BITS}-bit RSA DKIM key: $kf (selector $DKIM_SELECTOR)"
            local f; f="$(write_records_file "$domain" "$pub")"
            ok "wrote pasteable DNS records: $f"
            info "outbound $domain mail signs immediately (qmail-dkim reads the key per message)."
            info "publish the SPF + DKIM records, then: dsmr-email-admin authdns verify $domain"
            ;;
        show)
            local domain="${1:-}"; [ -n "$domain" ] || die "usage: dkim show <domain>"
            local kf="$keydir/$domain:$DKIM_SELECTOR"
            [ -f "$kf" ] || die "no DKIM key for $domain at $kf (run: dkim genkey $domain)"
            local pub; pub="$(cat "$kf.pub" 2>/dev/null)"; [ -n "$pub" ] || pub="$(dkim_pubkey "$kf")"
            cat "$(write_records_file "$domain" "$pub")"
            ;;
        verify)
            local domain="${1:-}"; [ -n "$domain" ] || die "usage: dkim verify <domain>"
            local kf="$keydir/$domain:$DKIM_SELECTOR"
            [ -f "$kf" ] || die "no local DKIM key for $domain at $kf"
            command -v dig >/dev/null 2>&1 || die "dig not found (install bind9-dnsutils)"
            local localpub dnsraw dnsp
            localpub="$(cat "$kf.pub" 2>/dev/null)"; [ -n "$localpub" ] || localpub="$(dkim_pubkey "$kf")"
            dnsraw="$(dig +short TXT "${DKIM_SELECTOR}._domainkey.${domain}" 2>/dev/null | tr -d '"[:space:]')"
            dnsp="$(printf '%s' "$dnsraw" | sed -n 's/.*p=\([A-Za-z0-9+/=]*\).*/\1/p')"
            if [ -z "$dnsp" ]; then
                bad "no DKIM key published at ${DKIM_SELECTOR}._domainkey.${domain}"; return 1
            fi
            if [ "$dnsp" = "$localpub" ]; then
                ok "DKIM published key matches local signing key for $domain"
            else
                bad "DKIM TXT is published but does NOT match the local key for $domain (stale record?)"; return 1
            fi
            ;;
        ""|-h|--help)
            echo "usage: dsmr-email-admin dkim {list | genkey <domain> [-s sel] [-b bits] [--force] | show <domain> | verify <domain>}" ;;
        *) die "unknown dkim action: $action (list genkey show verify)" ;;
    esac
}

cmd_spf() {
    local action="${1:-}"; shift || true
    local domain=""
    while [ $# -gt 0 ]; do case "$1" in
        --hard)      SPF_QUALIFIER="-all"; shift ;;
        --soft)      SPF_QUALIFIER="~all"; shift ;;
        --relay)     RELAYHOST="$2"; shift 2 ;;
        -*)          die "spf: unknown option $1" ;;
        *)           domain="$1"; shift ;;
    esac; done
    case "$action" in
        suggest)
            [ -n "$domain" ] || die "usage: spf suggest <domain> [--hard|--soft] [--relay host]"
            echo "Recommended SPF for ${domain} (TXT at the apex):"
            echo "  $(build_spf)"
            info "host/name '@' (the bare domain); switch --hard for -all once you are sure"
            info "${domain} sends only via ${RELAYHOST}."
            ;;
        verify)
            [ -n "$domain" ] || die "usage: spf verify <domain>"
            command -v dig >/dev/null 2>&1 || die "dig not found (install bind9-dnsutils)"
            local cur ip
            cur="$(spf_published "$domain")"
            if [ -z "$cur" ]; then bad "no SPF record published for $domain"; return 1; fi
            info "published: $cur"
            ip="$(dig +short A "$RELAYHOST" 2>/dev/null | head -1)"
            if printf '%s' "$cur" | grep -qiE "a:${RELAYHOST}([[:space:]]|$)" \
               || { [ -n "$ip" ] && printf '%s' "$cur" | grep -qF "ip4:$ip"; } \
               || printf '%s' "$cur" | grep -qiE '(^|[[:space:]])mx([[:space:]]|$)'; then
                ok "SPF authorizes the sending host (${RELAYHOST}${ip:+ / $ip}) for $domain"
            else
                bad "SPF for $domain does not appear to authorize ${RELAYHOST} (${ip:-?})"; return 1
            fi
            ;;
        ""|-h|--help)
            echo "usage: dsmr-email-admin spf {suggest <domain> [--hard|--soft] [--relay host] | verify <domain>}" ;;
        *) die "unknown spf action: $action (suggest verify)" ;;
    esac
}

# Every domain relevant to sender auth: the vpopmail virtual domains plus any
# domain that already has a signing key (e.g. the system/local domain, which is
# not under /home/vpopmail/domains but is still signed and audited).
keyed_domains() {
    local kd; kd="$(dkim_keydir)"
    ls "$kd" 2>/dev/null | grep -E ":${DKIM_SELECTOR}\$" | sed -E "s/:${DKIM_SELECTOR}\$//"
}
all_authdns_domains() { { ls "$VPOPDOMAINS" 2>/dev/null; keyed_domains; } | sort -u; }

# Echo "key dkimdns spf dmarc" for one domain.  Each is yes/no, or '?' when dig
# is unavailable.
authdns_domain_state() {
    local d="$1" kd; kd="$(dkim_keydir)"
    local key=no kdv=no spf=no dmarc=no
    [ -f "$kd/$d:$DKIM_SELECTOR" ] && key=yes
    if command -v dig >/dev/null 2>&1; then
        [ -n "$(dig +short TXT "${DKIM_SELECTOR}._domainkey.$d" 2>/dev/null | tr -d '"[:space:]' | grep -o 'p=[A-Za-z0-9+/=]\{1,\}')" ] && kdv=yes
        [ -n "$(spf_published "$d")" ] && spf=yes
        dig +short TXT "_dmarc.$d" 2>/dev/null | grep -qi 'v=DMARC1' && dmarc=yes
    else
        kdv=? ; spf=? ; dmarc=?
    fi
    echo "$key $kdv $spf $dmarc"
}

# Narrative findings report: classify every domain and explain the consequence.
authdns_report_body() {
    local host; host="$(hostname -f 2>/dev/null)"; [ -n "$host" ] || host="$(hostname)"
    local total=0 covered=0 minimal=0 blocked=0 signnodns=0
    local blocked_list="" minimal_list="" covered_list="" signnodns_list="" d k kd sp dm
    for d in $(all_authdns_domains); do
        total=$((total+1))
        read -r k kd sp dm <<<"$(authdns_domain_state "$d")"
        [ "$k" = yes ] && [ "$kd" = no ] && { signnodns=$((signnodns+1)); signnodns_list="$signnodns_list $d"; }
        if   [ "$kd" = yes ] && [ "$sp" = yes ]; then covered=$((covered+1)); covered_list="$covered_list $d"
        elif [ "$kd" = yes ] || [ "$sp" = yes ];  then minimal=$((minimal+1)); minimal_list="$minimal_list $d"
        elif [ "$kd" = no ]  && [ "$sp" = no ];   then blocked=$((blocked+1)); blocked_list="$blocked_list $d"
        fi
    done
    echo "DSMR sender-authentication report"
    echo "host: ${host}   selector: ${DKIM_SELECTOR}   generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo
    echo "Findings"
    echo "  domains examined .......... ${total}"
    echo "  fully covered (SPF+DKIM) .. ${covered}"
    echo "  minimal (one of SPF/DKIM) . ${minimal}"
    echo "  unauthenticated (neither) . ${blocked}"
    echo "  signed but DKIM not in DNS  ${signnodns}"
    echo
    if [ "$blocked" -gt 0 ]; then
        echo "UNAUTHENTICATED — neither SPF nor DKIM published:"
        for d in $blocked_list; do echo "    - $d"; done
        echo "  Result: receivers cannot authenticate mail from these domains.  Gmail and"
        echo "  Yahoo reject it outright with '550-5.7.26 ... the sender is unauthenticated'"
        echo "  — the mail bounces, it is not spam-foldered.  Mail to those providers from"
        echo "  these domains is currently UNDELIVERABLE."
        echo "  Fix: authdns provision <domain>; publish the record file at the domain's"
        echo "  nameserver; authdns verify <domain>."
        echo
    fi
    if [ "$signnodns" -gt 0 ]; then
        echo "SIGNED LOCALLY BUT DKIM NOT PUBLISHED:"
        for d in $signnodns_list; do echo "    - $d"; done
        echo "  Result: outbound mail carries a DKIM-Signature, but receivers find no"
        echo "  matching key in DNS, so DKIM evaluates to fail/none until the record is"
        echo "  published.  Publish the DKIM TXT, then authdns verify <domain>."
        echo
    fi
    if [ "$minimal" -gt 0 ]; then
        echo "MINIMALLY AUTHENTICATED — exactly one of SPF/DKIM published:"
        for d in $minimal_list; do echo "    - $d"; done
        echo "  Result: clears the Gmail/Yahoo 'SPF or DKIM' bar, so mail is accepted, but"
        echo "  DMARC alignment requires BOTH.  Add the missing record to be robust and"
        echo "  DMARC-ready."
        echo
    fi
    if [ "$covered" -gt 0 ]; then
        echo "FULLY AUTHENTICATED (SPF + DKIM published):"
        for d in $covered_list; do echo "    - $d"; done
        echo
    fi
    echo "Ramifications"
    echo "  Since 2024 Gmail and Yahoo require senders to authenticate with SPF or DKIM"
    echo "  (and to honour DMARC).  A domain with neither is rejected at the remote SMTP"
    echo "  server.  DKIM additionally survives forwarding, where SPF breaks, so signing"
    echo "  every domain is the durable fix.  The records generated here authorize this"
    echo "  host (${host}) as the sender; publish them wherever each domain's DNS lives."
}

cmd_authdns() {
    local action="${1:-}"; shift || true
    case "$action" in
        provision)
            case "${1:-}" in
                ""|-h|--help) echo "usage: dsmr-email-admin authdns provision <domain> [-s sel] [-b bits] [--force]"; return 0 ;;
            esac
            local domain="$1"; shift
            cmd_dkim genkey "$domain" "$@"
            ;;
        provision-all)
            # Only provision domains that have NO sender authentication yet.  A
            # domain that already publishes SPF or DKIM is sending through some
            # other path (an external ESP, a different MTA) — installing an
            # outrider key and republishing its records would break that.  Such
            # domains are skipped unless --include-external is given.
            local force_ext=0 passthru=()
            while [ $# -gt 0 ]; do case "$1" in
                -h|--help) echo "usage: dsmr-email-admin authdns provision-all [--include-external] [-b bits] [-s sel]"; return 0 ;;
                --include-external) force_ext=1; shift ;;
                *) passthru+=("$1"); shift ;;
            esac; done
            need_root
            local keydir; keydir="$(dkim_keydir)"
            local d kf k kd sp dm made=0 keyed=0 ext=0
            for d in $(all_authdns_domains); do
                kf="$keydir/$d:$DKIM_SELECTOR"
                if [ -f "$kf" ]; then info "skip $d (key already installed)"; keyed=$((keyed+1)); continue; fi
                read -r k kd sp dm <<<"$(authdns_domain_state "$d")"
                if [ "$force_ext" != 1 ] && { [ "$sp" = yes ] || [ "$kd" = yes ]; }; then
                    warn "skip $d (already publishes SPF/DKIM — managed elsewhere; --include-external to override)"
                    ext=$((ext+1)); continue
                fi
                echo "==> $d"; cmd_dkim genkey "$d" "${passthru[@]}" && made=$((made+1))
            done
            echo "=== provisioned $made; skipped $keyed keyed, $ext externally-managed; record files in $AUTHDNS_OUT ==="
            ;;
        status)
            local only="${1:-}"
            command -v dig >/dev/null 2>&1 || warn "dig not found — DNS columns read '?' (install bind9-dnsutils)"
            printf "%-30s %-4s %-8s %-4s %-6s\n" "DOMAIN" "KEY" "DKIM-DNS" "SPF" "DMARC"
            local d k kd sp dm
            for d in $(all_authdns_domains); do
                [ -n "$only" ] && [ "$d" != "$only" ] && continue
                read -r k kd sp dm <<<"$(authdns_domain_state "$d")"
                printf "%-30s %-4s %-8s %-4s %-6s\n" "$d" "$k" "$kd" "$sp" "$dm"
            done
            ;;
        report)
            local out=""
            while [ $# -gt 0 ]; do case "$1" in
                -o|--out) out="$2"; shift 2 ;;
                -*)       die "authdns report: unknown option $1" ;;
                *)        shift ;;
            esac; done
            command -v dig >/dev/null 2>&1 || warn "dig not found — DNS findings unavailable (install bind9-dnsutils)"
            if [ -n "$out" ]; then
                authdns_report_body > "$out"; echo "report written: $out"; cat "$out"
            else
                authdns_report_body
            fi
            ;;
        verify)
            local domain="${1:-}"; [ -n "$domain" ] || die "usage: authdns verify <domain>"
            echo "==> SPF";  cmd_spf  verify "$domain"
            echo "==> DKIM"; cmd_dkim verify "$domain"
            ;;
        ""|-h|--help)
            echo "usage: dsmr-email-admin authdns {provision <domain> | provision-all | status [domain] | report [-o file] | verify <domain>}" ;;
        *) die "unknown authdns action: $action (provision provision-all status report verify)" ;;
    esac
}

# ── reputation / backscatter diagnostics ──────────────────────────────────────
#
# A host's outbound IP reputation is wrecked when it emits misdirected bounces
# (backscatter): it accepts mail to a local recipient that then fails delivery,
# and qmail bounces it to the (usually forged) sender.  Receivers see a flood of
# unsolicited bounces from the IP and flag it.  These tools detect backscatter,
# find its source, test the RCPT gate as a real external sender, and purge the
# backscatter queue.

# Envelope sender of queued message <id>; empty output means a null sender (<>),
# i.e. a bounce.  Returns non-zero if the message can't be read.
queue_sender() {
    local inf; inf=$(ls "$QUEUE"/info/*/"$1" 2>/dev/null | head -1)
    [ -n "$inf" ] || return 1
    tr '\0' '\n' < "$inf" | sed -n '1s/^F//p'
}

reputation_audit() {
    need_root
    echo "=== outbound reputation / backscatter audit ==="
    local ids id s total null=0 real=0
    ids=$(ls "$QUEUE"/info/*/* 2>/dev/null | xargs -rn1 basename | sort -u)
    total=$(printf '%s\n' "$ids" | grep -c .)
    for id in $(printf '%s\n' "$ids" | head -1500); do
        s=$(queue_sender "$id") || continue
        if [ -z "$s" ]; then null=$((null+1)); else real=$((real+1)); fi
    done
    echo "--- queue ---"
    echo "messages: $total   (sample: bounce/null-sender=$null  real-sender=$real)"
    if [ "$total" -gt 50 ] && [ "$null" -gt "$real" ]; then
        bad "queue is mostly null-sender bounces — BACKSCATTER in progress"
    else
        ok "queue not dominated by bounces"
    fi

    echo "--- accept-then-bounce recipients (from queued failure notices) ---"
    local tmp; tmp=$(mktemp)
    local f n=0
    for f in $(find "$QUEUE/mess" -type f 2>/dev/null | head -1500); do
        grep -qim1 'failure notice\|invoked for bounce' "$f" 2>/dev/null || continue
        n=$((n+1))
        grep -oiE '^<[^>]+@[^>]+>:' "$f" 2>/dev/null | head -1 | sed -E 's/^<//; s/>:$//' >> "$tmp"
    done
    if [ "$n" -gt 0 ]; then
        echo "top bounced recipients (of $n bounces sampled):"
        sort "$tmp" | uniq -c | sort -rn | head -10 | sed 's/^/  /'
        echo "classification of the distinct local recipients:"
        local addr lp dom base
        for addr in $(sort -u "$tmp" | head -20); do
            lp=${addr%@*}; dom=${addr#*@}; base=${lp%%-*}
            if id "$base" >/dev/null 2>&1; then
                local h; h=$(getent passwd "$base" | cut -d: -f6)
                if [ -d "$h/Maildir/new" ]; then
                    info "$addr — real user, Maildir OK (transient?)"
                else
                    bad "$addr — REAL user '$base' but no Maildir/new => delivery bounces (create his Maildir)"
                fi
            else
                warn "$addr — no such user '$base' => accepted-then-bounced (RCPT gate gap)"
            fi
        done
    else
        ok "no failure-notice bounces sampled in the queue"
    fi
    rm -f "$tmp"

    echo "--- alias catch-all (a bouncing fastforward is a classic faucet) ---"
    local ah qd; ah=$(getent passwd alias 2>/dev/null | cut -d: -f6); qd="$ah/.qmail-default"
    if [ -n "$ah" ] && [ -f "$qd" ]; then
        if grep -q 'fastforward' "$qd" && ! grep -qE '(^|[[:space:]])-[a-zA-Z]*p' "$qd"; then
            bad "$qd runs fastforward WITHOUT -p — unknown recipients bounce: $(cat "$qd")"
            info "fix: add -p (pass-through, no bounce) and reject unknowns at RCPT instead"
        else
            ok "$qd: $(cat "$qd")"
        fi
    fi

    echo "--- forwarding to external freemail (re-emitted spam hurts the IP) ---"
    local fwd; fwd=$(grep -rhsE '^&[a-zA-Z0-9._%+-]+@(gmail|googlemail|yahoo|hotmail|outlook|live|icloud|aol)\.' \
                     "$VPOPDOMAINS" 2>/dev/null | wc -l)
    [ "$fwd" -gt 0 ] && warn "$fwd vpopmail addresses forward to freemail" || ok "no vpopmail freemail forwards"
    echo "=== ${PASS} pass, ${WARN} warn, ${FAIL} fail ==="
    [ "$FAIL" -eq 0 ]
}

# Test the RCPT gate as a real external (non-relayclient) sender.  Connects to
# this host's OWN public IP, because 127.0.0.1 is a RELAYCLIENT and would accept
# any recipient, hiding what an outside sender actually sees.  Sends no DATA.
reputation_probe() {
    local addr="${1:-}"
    case "$addr" in ""|-h|--help) echo "usage: dsmr-email-admin reputation probe <local@domain>"; return 0 ;; esac
    command -v python3 >/dev/null 2>&1 || die "python3 required"
    local ip; ip=$(ip route get 1.1.1.1 2>/dev/null | sed -n 's/.*src \([0-9.]*\).*/\1/p' | head -1)
    [ -n "$ip" ] || ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    [ -n "$ip" ] || die "could not determine a non-loopback local IP to probe"
    echo "RCPT probe of <$addr> via non-relayclient path ($ip -> $ip:25):"
    python3 - "$ip" "$addr" <<'PY'
import socket, sys
ip, addr = sys.argv[1], sys.argv[2]
s = socket.create_connection((ip, 25), timeout=20); s.settimeout(15)
def rd():
    try: return s.recv(4096).decode(errors="replace").strip()
    except Exception: return "(timeout)"
print("  banner:", rd())
def cmd(c):
    s.sendall((c + "\r\n").encode()); print(f"  >> {c}\n     {rd()}")
cmd("EHLO reputation-probe.invalid")
cmd("MAIL FROM:<reputation-probe@example.com>")
cmd(f"RCPT TO:<{addr}>")
cmd("QUIT"); s.close()
PY
    echo "  (250 on a deliberately-invalid address = the gate accepts-then-bounces"
    echo "   => backscatter; 550 = it rejects cleanly.)"
}

# Purge backscatter: messages that are BOTH null-sender AND Subject "failure
# notice".  Dry-run unless --commit.  Stops qmail-send for the surgery.
reputation_purge() {
    need_root
    local commit=0; [ "${1:-}" = "--commit" ] && commit=1
    local ids id s mess match=0 matchids=""
    ids=$(ls "$QUEUE"/info/*/* 2>/dev/null | xargs -rn1 basename | sort -u)
    for id in $ids; do
        s=$(queue_sender "$id") || continue
        [ -z "$s" ] || continue
        mess=$(ls "$QUEUE"/mess/*/"$id" 2>/dev/null | head -1); [ -n "$mess" ] || continue
        grep -qm1 '^Subject: failure notice' "$mess" 2>/dev/null || continue
        match=$((match+1)); matchids="$matchids $id"
    done
    echo "backscatter (null-sender + failure notice): $match message(s)"
    [ "$commit" = 1 ] || { echo "(dry-run; re-run 'reputation purge --commit' to delete)"; return 0; }
    local sdir=""
    for d in /service/qmail-send /etc/service/qmail-send /var/lib/qmail/supervise/qmail-send; do
        [ -d "$d" ] && { sdir="$d"; break; }
    done
    [ -n "$sdir" ] || die "qmail-send service dir not found"
    echo "stopping qmail-send..."; svc -d "$sdir"; sleep 2
    local del=0
    for id in $matchids; do
        rm -f "$QUEUE"/mess/*/"$id" "$QUEUE"/info/*/"$id" "$QUEUE"/local/*/"$id" \
              "$QUEUE"/remote/*/"$id" "$QUEUE"/intd/*/"$id" "$QUEUE"/todo/*/"$id" \
              "$QUEUE"/bounce/"$id" 2>/dev/null
        del=$((del+1))
    done
    echo "restarting qmail-send..."; svc -u "$sdir"; sleep 2
    ok "purged $del backscatter messages"
    "$QBIN/qmail-qstat" 2>/dev/null || true
}

cmd_reputation() {
    local action="${1:-audit}"; shift || true
    case "$action" in
        audit|"")  reputation_audit "$@" ;;
        probe)     reputation_probe "$@" ;;
        purge)     reputation_purge "$@" ;;
        -h|--help) echo "usage: dsmr-email-admin reputation {audit | probe <local@domain> | purge [--commit]}" ;;
        *) die "unknown reputation action: $action (audit probe purge)" ;;
    esac
}

usage() {
    cat <<EOF
Usage: dsmr-email-admin <command> [args]

  check                Read-only health check of the DSMR mail stack.
  fix [--dry-run] [TARGET...]
                       Repair detected issues.  TARGETs:
                         softlimit     raise control/softlimit to ${SOFTLIMIT_MIN}
                         pgsql-config  fix swapped vpopmail.pgsql password/database
                         dovecot-sql   regenerate dovecot SQL conf from vpopmail.pgsql
                         pg-cluster    start + enable the vpopmail postgres cluster
                       With no TARGET, fixes everything detected.
  selftest [DOMAIN]    End-to-end delivery + auth probe (creates and removes a
                       throwaway vpopmail mailbox).

  dkim list            Show which vpopmail domains have a DKIM signing key.
  dkim genkey DOMAIN [-s selector] [-b bits] [--force]
                       Generate + install a DKIM key (default ${DKIM_BITS}-bit RSA,
                       selector '${DKIM_SELECTOR}') so outbound DOMAIN mail signs
                       immediately, and write its pasteable DNS records.
  dkim show DOMAIN     Re-emit DOMAIN's SPF+DKIM record file and print it.
  dkim verify DOMAIN   Confirm the published DKIM TXT matches the local key.

  spf suggest DOMAIN [--hard|--soft] [--relay HOST]
                       Print the recommended SPF record (default ~all via
                       a:${RELAYHOST}).
  spf verify DOMAIN    Confirm the published SPF authorizes the sending host.

  authdns provision DOMAIN        genkey DOMAIN + write its record file.
  authdns provision-all [--include-external]
                                  Provision every domain with no SPF/DKIM yet
                                  (skips externally-managed domains).
  authdns status [DOMAIN]         Coverage table: key / DKIM-DNS / SPF / DMARC.
  authdns report [-o FILE]        Narrative findings + ramifications across domains.
  authdns verify DOMAIN           Run spf verify + dkim verify.

  reputation audit                Detect backscatter and find its source.
  reputation probe LOCAL@DOMAIN   Test the RCPT gate as a real external sender.
  reputation purge [--commit]     Purge null-sender "failure notice" backscatter.

  version | help

Fixes back up each file (<file>.bak-<timestamp>) before changing it.
DKIM/SPF management never writes to a nameserver: it writes pasteable record
files to ${AUTHDNS_OUT}/<domain> for manual publication.
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
    check)            cmd_check "$@" ;;
    fix)              cmd_fix "$@" ;;
    selftest)         cmd_selftest "$@" ;;
    dkim)             cmd_dkim "$@" ;;
    spf)              cmd_spf "$@" ;;
    authdns)          cmd_authdns "$@" ;;
    reputation)       cmd_reputation "$@" ;;
    version|--version) echo "dsmr-email-admin 1.0" ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command: $cmd (try: dsmr-email-admin --help)" ;;
esac
